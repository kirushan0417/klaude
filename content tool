<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KLAUDE</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0b0b0e;--s1:#111116;--s2:#18181f;--s3:#202028;--s4:#2c2c38;
  --border:rgba(255,255,255,.055);--border2:rgba(255,255,255,.10);
  --text:#f2f0ec;--muted:rgba(242,240,236,.35);--muted2:rgba(242,240,236,.6);
  --accent:#d4af37;--r:9px;
  --font:'DM Sans',sans-serif;--fh:'Bebas Neue',sans-serif;--fm:'DM Mono',monospace;
}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;overflow:hidden;}
body{background:var(--bg);color:var(--text);font-family:var(--font);display:flex;flex-direction:column;height:100vh;font-size:13px;}

/* TOPBAR */
.topbar{height:56px;background:var(--s1);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 18px;gap:12px;flex-shrink:0;}
.logo{font-family:var(--fh);font-size:24px;letter-spacing:.04em;color:var(--text);white-space:nowrap;flex-shrink:0;}
.logo span{color:var(--accent);}
.brand-sw{display:flex;gap:3px;background:var(--s2);border:1px solid var(--border);border-radius:10px;padding:3px;flex-shrink:0;}
.btab{font-family:var(--fh);font-size:12px;letter-spacing:.07em;padding:5px 14px;border-radius:7px;border:none;background:transparent;color:var(--muted);cursor:pointer;transition:all .2s;white-space:nowrap;}
.btab:hover{color:var(--text);}
.btab.jc-on{background:linear-gradient(135deg,#2a2010,#1e1800);color:#d4af37;box-shadow:0 0 0 1px rgba(212,175,55,.28);}
.btab.ace-on{background:linear-gradient(135deg,#0d1828,#091220);color:#4d9fff;box-shadow:0 0 0 1px rgba(77,159,255,.28);}
.btab.fs-on{background:linear-gradient(135deg,#1a0e2a,#120920);color:#a855f7;box-shadow:0 0 0 1px rgba(168,85,247,.28);}
.keys{display:flex;align-items:center;gap:6px;margin-left:auto;flex-shrink:0;}
.kw{display:flex;align-items:center;gap:5px;background:var(--s2);border:1px solid var(--border);border-radius:7px;padding:4px 9px;}
.kl{font-size:9px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);white-space:nowrap;}
.kdot{width:5px;height:5px;border-radius:50%;background:var(--s4);flex-shrink:0;transition:background .2s;}
.kdot.ok{background:#22c55e;}
.kinput{background:transparent;border:none;color:var(--text);font-family:var(--fm);font-size:10px;width:110px;outline:none;}
.kinput::placeholder{color:var(--muted);}

/* MAIN */
.main{display:grid;grid-template-columns:300px 1fr;flex:1;overflow:hidden;min-height:0;}

/* SIDEBAR */
.sb{background:var(--s1);border-right:1px solid var(--border);overflow-y:auto;display:flex;flex-direction:column;scrollbar-width:thin;scrollbar-color:var(--s4) transparent;}
.sb::-webkit-scrollbar{width:3px;}
.sb::-webkit-scrollbar-thumb{background:var(--s4);border-radius:3px;}
.panel{display:none;flex-direction:column;}
.panel.active{display:flex;}
.sec{padding:13px 13px 0;}
.seclabel{font-size:9px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-bottom:8px;display:flex;align-items:center;gap:7px;}
.seclabel::after{content:'';flex:1;height:1px;background:var(--border);}

/* count */
.count-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:4px;}
.cbtn{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;padding:8px 4px;border-radius:8px;border:1px solid var(--border);background:var(--s2);cursor:pointer;transition:all .18s;}
.cbtn:hover{border-color:var(--border2);background:var(--s3);}
.cbtn.on{border-color:var(--accent);background:rgba(212,175,55,.08);}
.cbtn .n{font-family:var(--fh);font-size:22px;color:var(--muted2);line-height:1;transition:color .18s;}
.cbtn.on .n{color:var(--accent);}
.cbtn .w{font-size:8px;font-weight:600;letter-spacing:.09em;text-transform:uppercase;color:var(--muted);}

/* buttons */
.fbtn{width:100%;padding:12px;border-radius:var(--r);border:none;font-family:var(--fh);font-size:15px;letter-spacing:.09em;cursor:pointer;transition:all .2s;}
.fbtn:disabled{opacity:.4;cursor:not-allowed;}
.fbtn:active{transform:scale(.98);}
.fbtn.jc{background:linear-gradient(135deg,#d4af37,#b8960f);color:#000;}
.fbtn.ace{background:linear-gradient(135deg,#4d9fff,#1a6fd4);color:#000;}
.ldr{display:none;align-items:center;gap:7px;padding-top:8px;font-size:11px;color:var(--muted2);}
.ldr.on{display:flex;}
.spin{width:12px;height:12px;border:1.5px solid rgba(255,255,255,.08);border-top-color:var(--accent);border-radius:50%;animation:spin .6s linear infinite;flex-shrink:0;}
@keyframes spin{to{transform:rotate(360deg);}}

/* story cards */
.slist{display:flex;flex-direction:column;gap:4px;}
.scard{border-radius:7px;border:1px solid var(--border);background:var(--s2);padding:9px 10px;cursor:pointer;transition:border-color .15s,transform .12s;}
.scard:hover{border-color:var(--border2);transform:translateX(2px);}
.scard.on{border-color:var(--accent);}
.scard.on.ace-card{border-color:#4d9fff;}
.scard-top{display:flex;align-items:center;gap:6px;margin-bottom:4px;}
.spill{font-size:8px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:2px 7px;border-radius:3px;color:#000;flex-shrink:0;}
.snum{font-family:var(--fh);font-size:11px;color:var(--muted);margin-left:auto;}
.stitle{font-family:var(--fh);font-size:12px;letter-spacing:.03em;line-height:1.3;color:var(--text);}
.src-link{display:inline-flex;align-items:center;gap:5px;margin-top:6px;font-size:9px;font-weight:600;letter-spacing:.07em;text-transform:uppercase;color:var(--muted);text-decoration:none;border:1px solid var(--border);border-radius:4px;padding:3px 8px;transition:color .15s,border-color .15s;}
.src-link:hover{color:var(--text);border-color:var(--border2);}
.src-link svg{flex-shrink:0;}
.empty{display:flex;flex-direction:column;align-items:center;gap:5px;padding:18px 0;color:var(--muted);font-size:11px;text-align:center;}
.eicon{font-size:26px;opacity:.3;margin-bottom:3px;}

/* photo grid */
.igrid{display:grid;grid-template-columns:repeat(4,1fr);gap:3px;}
.ithumb{aspect-ratio:1/1;object-fit:cover;border-radius:4px;cursor:pointer;border:2px solid transparent;opacity:.55;width:100%;transition:opacity .15s,border-color .15s;background:var(--s3);}
.ithumb:hover{opacity:.9;}
.ithumb.on{opacity:1;border-color:var(--accent);}
.imsg{grid-column:1/-1;font-size:10px;color:var(--muted);padding:4px 0;display:flex;align-items:center;gap:5px;}

/* fields */
.field{display:flex;flex-direction:column;gap:4px;}
.field label{font-size:9px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);}
textarea,input[type=text],input[type=password]{background:var(--s2);border:1px solid var(--border);border-radius:6px;color:var(--text);font-family:var(--font);font-size:12px;padding:7px 10px;width:100%;outline:none;resize:none;line-height:1.5;transition:border-color .18s;}
textarea:focus,input[type=text]:focus,input[type=password]:focus{border-color:var(--border2);}
.brow{display:flex;align-items:center;gap:8px;}
.brow input[type=range]{flex:1;accent-color:var(--accent);cursor:pointer;}
.bval{font-family:var(--fm);font-size:11px;color:var(--accent);min-width:32px;text-align:right;}
.dlbtn{width:100%;background:var(--s2);color:var(--text);font-family:var(--fh);font-size:14px;letter-spacing:.1em;padding:11px;border-radius:var(--r);border:1px solid var(--border2);cursor:pointer;transition:all .18s;display:flex;align-items:center;justify-content:center;gap:8px;}
.dlbtn:hover{background:var(--s3);}
.dlbtn:active{transform:scale(.98);}

/* failsafe */
.fs-note{font-size:11px;color:var(--muted2);line-height:1.6;background:var(--s2);border:1px solid var(--border);border-radius:8px;padding:12px;}
.fs-note strong{color:var(--text);display:block;margin-bottom:5px;}
.fs-note code{font-family:var(--fm);font-size:10px;color:#a855f7;background:rgba(168,85,247,.1);padding:1px 5px;border-radius:3px;}
.fs-group{display:flex;flex-direction:column;gap:7px;}
.fs-label{font-size:9px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:2px;display:block;}
.fs-toggle{display:flex;align-items:center;gap:8px;cursor:pointer;}
.fs-toggle input[type=checkbox]{accent-color:#a855f7;width:13px;height:13px;cursor:pointer;}
.fs-toggle span{font-size:11px;color:var(--muted2);}
.fs-status{font-size:10px;text-align:center;color:#22c55e;min-height:14px;}

/* preview */
.prev{background:#06060a;display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative;}
.prev::before{content:'';position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.014) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.014) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;}
.pinner{display:flex;flex-direction:column;align-items:center;gap:12px;position:relative;z-index:1;max-height:100%;}
canvas#postCanvas{display:block;border-radius:3px;box-shadow:0 24px 80px rgba(0,0,0,.9),0 0 0 1px rgba(255,255,255,.05);flex-shrink:0;}
.cap-card{background:var(--s1);border:1px solid var(--border);border-radius:10px;padding:11px 14px;flex-shrink:0;}
.cap-text{font-size:11px;line-height:1.65;color:var(--muted2);}
.cap-text strong{color:var(--text);font-weight:600;}
.cap-tags{color:#5a7fff;margin-top:4px;font-size:10px;line-height:1.6;}
.toast{position:absolute;bottom:14px;left:50%;transform:translateX(-50%);background:var(--s1);border:1px solid var(--border);border-radius:20px;padding:5px 16px;font-size:10px;color:var(--muted2);opacity:0;transition:opacity .3s;pointer-events:none;white-space:nowrap;z-index:10;}
.toast.show{opacity:1;}

body.ace .cbtn.on{border-color:#4d9fff;background:rgba(77,159,255,.08);}
body.ace .cbtn.on .n{color:#4d9fff;}
body.ace .spin{border-top-color:#4d9fff;}
body.ace .brow input[type=range]{accent-color:#4d9fff;}
body.ace .bval{color:#4d9fff;}
body.ace .ithumb.on{border-color:#4d9fff;}
body.ace .scard.on{border-color:#4d9fff;}
</style>
</head>
<body>

<div class="topbar">
  <div class="logo" style="font-size:24px;letter-spacing:.04em;">KL<span style="color:var(--accent);">AUDE</span></div>

  <!-- centered keys -->
  <div class="keys" style="margin-left:auto;margin-right:auto;">
    <div class="kw">
      <span class="kl">Claude</span>
      <div class="kdot" id="cdot"></div>
      <input class="kinput" id="kClaude" type="password" placeholder="sk-ant-..." oninput="kcheck('kClaude','cdot')">
    </div>
    <div class="kw">
      <span class="kl">Pexels</span>
      <div class="kdot" id="pxdot"></div>
      <input class="kinput" id="kPexels" type="text" placeholder="pexels key..." oninput="kcheck('kPexels','pxdot');syncPexelsKey()">
    </div>
    <div class="kw" style="gap:6px;">
      <span class="kl">News</span>
      <div class="kdot ok"></div>
      <span style="font-family:var(--fm);font-size:10px;color:var(--muted2);" id="srcLabel">CBC ✓</span>
    </div>
  </div>

  <!-- brand tabs right -->
  <div class="brand-sw">
    <button class="btab jc-on" id="tabJC"  onclick="switchBrand('jc')">🎰 Jackpot City CA</button>
    <button class="btab"       id="tabACE" onclick="switchBrand('ace')">🃏 ACE.com USA</button>
    <button class="btab"       id="tabFS"  onclick="switchBrand('fs')">⚡ Failsafe</button>
  </div>
</div>

<div class="main">
<div class="sb">

  <!-- MAIN PANEL -->
  <div class="panel active" id="panelMain">

    <div class="sec" style="padding-bottom:13px;">
      <div class="seclabel">How many posts</div>
      <div class="count-grid">
        <div class="cbtn on" data-n="1" onclick="pickN(this)"><span class="n">1</span><span class="w">post</span></div>
        <div class="cbtn"    data-n="2" onclick="pickN(this)"><span class="n">2</span><span class="w">posts</span></div>
        <div class="cbtn"    data-n="3" onclick="pickN(this)"><span class="n">3</span><span class="w">posts</span></div>
        <div class="cbtn"    data-n="4" onclick="pickN(this)"><span class="n">4</span><span class="w">posts</span></div>
      </div>
    </div>

    <div class="sec" style="padding-bottom:13px;">
      <button class="fbtn jc" id="fbtn" onclick="doFetch()">⚡ GENERATE POSTS</button>
      <div class="ldr" id="ldr"><div class="spin" id="spinEl"></div><span id="lmsg">Working...</span></div>
    </div>

    <div class="sec" style="padding-bottom:13px;">
      <div class="seclabel">Original Source</div>
      <div id="srcPanel" style="background:var(--s2);border:1px solid var(--border);border-radius:8px;padding:10px 12px;">
        <div style="font-size:10px;color:var(--muted);font-style:italic;">Generate posts to see source link</div>
      </div>
    </div>

    <div class="sec" style="padding-bottom:13px;">
      <div class="seclabel">Live Stories</div>
      <div class="slist" id="slist">
        <div class="empty"><div class="eicon">✦</div>Hit Generate to pull today's stories</div>
      </div>
    </div>

    <div class="sec" style="padding-bottom:13px;">
      <div class="seclabel">Images — Phase 2</div>
      <!-- Pexels search -->
      <div style="display:flex;gap:6px;margin-bottom:7px;">
        <input type="text" id="imgQuery" placeholder="Search Pexels or type topic..." style="flex:1;font-size:11px;padding:6px 9px;">
        <button onclick="searchPexels()" style="background:var(--accent);color:#000;border:none;border-radius:6px;padding:6px 11px;font-family:var(--fh);font-size:12px;letter-spacing:.06em;cursor:pointer;white-space:nowrap;">Search</button>
      </div>
      <div style="font-size:9px;color:var(--muted);margin-bottom:7px;">
        Add your Pexels key in Failsafe tab → searches auto. Or type any topic and hit Search.
      </div>
      <div class="igrid" id="igrid">
        <div class="imsg">Enter a Pexels key in Failsafe tab, or type a topic above</div>
      </div>
    </div>

    <div class="sec" style="padding-bottom:13px;display:flex;flex-direction:column;gap:9px;">
      <div class="seclabel">Edit</div>

      <div class="field">
        <label>Handle Style</label>
        <div style="display:flex;gap:5px;">
          <button onclick="setHandleStyle('light')" id="btnHandleLight"
            style="flex:1;padding:6px;border-radius:6px;border:1px solid var(--accent);background:rgba(212,175,55,.15);color:var(--accent);font-family:var(--fh);font-size:12px;letter-spacing:.06em;cursor:pointer;">
            ☀ Light
          </button>
          <button onclick="setHandleStyle('dark')" id="btnHandleDark"
            style="flex:1;padding:6px;border-radius:6px;border:1px solid var(--border);background:var(--s2);color:var(--muted);font-family:var(--fh);font-size:12px;letter-spacing:.06em;cursor:pointer;">
            ● Dark
          </button>
        </div>
      </div>

      <div class="field">
        <label>Stripe above text</label>
        <div style="display:flex;gap:5px;">
          <button onclick="setStripe(true)" id="btnStripeOn"
            style="flex:1;padding:6px;border-radius:6px;border:1px solid var(--accent);background:rgba(212,175,55,.15);color:var(--accent);font-family:var(--fh);font-size:12px;letter-spacing:.06em;cursor:pointer;">
            On
          </button>
          <button onclick="setStripe(false)" id="btnStripeOff"
            style="flex:1;padding:6px;border-radius:6px;border:1px solid var(--border);background:var(--s2);color:var(--muted);font-family:var(--fh);font-size:12px;letter-spacing:.06em;cursor:pointer;">
            Off
          </button>
        </div>
      </div>

      <div class="field">
        <label>Headline</label>
        <textarea id="fHead" rows="2" oninput="renderCanvas()" style="font-family:'Bebas Neue',sans-serif;letter-spacing:.04em;font-size:14px;text-transform:uppercase;"></textarea>
      </div>
      <div class="field">
        <label>Caption</label>
        <textarea id="fCap" rows="3" oninput="updateCap()"></textarea>
      </div>
      <div class="field">
        <label>Brightness</label>
        <div class="brow">
          <input type="range" id="brightness" min="20" max="100" value="72" oninput="onBright(this.value)">
          <span class="bval" id="bval">72%</span>
        </div>
      </div>
    </div>

    <div class="sec" style="padding-bottom:16px;">
      <button class="dlbtn" onclick="download()">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download JPG
      </button>
    </div>
  </div>

  <!-- FAILSAFE PANEL -->
  <div class="panel" id="panelFS">

    <div class="sec" style="padding-bottom:13px;">
      <div class="seclabel">Failsafe</div>
      <div class="fs-note">
        <strong>⚡ Backup integrations</strong>
        If CBC or ABC News scraping stops working, enable one of these alternatives. Toggle ON and switch back to your brand tab — it activates automatically. Settings save in your browser.
      </div>
    </div>

    <div class="sec" style="padding-bottom:13px;">
      <div class="seclabel">NewsAPI <span style="font-size:9px;opacity:.5;margin-left:4px;">newsapi.org — free</span></div>
      <div class="fs-group">
        <div class="field">
          <label class="fs-label">API Key</label>
          <input type="text" id="fsNewsKey" placeholder="your newsapi key..." oninput="fsSave()">
        </div>
        <label class="fs-toggle">
          <input type="checkbox" id="fsNewsOn" onchange="fsSave()">
          <span>Use NewsAPI instead of RSS</span>
        </label>
      </div>
    </div>

    <div class="sec" style="padding-bottom:13px;">
      <div class="seclabel">Unsplash <span style="font-size:9px;opacity:.5;margin-left:4px;">unsplash.com/developers — free</span></div>
      <div class="fs-group">
        <div class="field">
          <label class="fs-label">Access Key</label>
          <input type="text" id="fsUnsplashKey" placeholder="your unsplash access key..." oninput="fsSave()">
        </div>
        <label class="fs-toggle">
          <input type="checkbox" id="fsUnsplashOn" onchange="fsSave()">
          <span>Use Unsplash if story has no image</span>
        </label>
      </div>
    </div>

    <div class="sec" style="padding-bottom:13px;">
      <div class="seclabel">Pexels <span style="font-size:9px;opacity:.5;margin-left:4px;">requires server.py locally</span></div>
      <div class="fs-group">
        <div class="field">
          <label class="fs-label">API Key</label>
          <input type="text" id="fsPexelsKey" placeholder="your pexels key..." oninput="fsSave()">
        </div>
        <label class="fs-toggle">
          <input type="checkbox" id="fsPexelsOn" onchange="fsSave()">
          <span>Use Pexels via local server.py</span>
        </label>
        <div class="fs-note" style="font-size:10px;margin-top:2px;">Pexels key is also in the topbar for quick access. Works on GitHub Pages ✓</div>
      </div>
    </div>

    <div class="sec" style="padding-bottom:13px;">
      <div class="seclabel">Custom RSS Feed</div>
      <div class="fs-group">
        <div class="field">
          <label class="fs-label">Feed URL</label>
          <input type="text" id="fsRssUrl" placeholder="https://yoursite.com/feed.rss" oninput="fsSave()">
        </div>
        <label class="fs-toggle">
          <input type="checkbox" id="fsRssOn" onchange="fsSave()">
          <span>Use this RSS instead of CBC/ABC</span>
        </label>
      </div>
    </div>

    <div class="sec" style="padding-bottom:16px;">
      <div class="fs-status" id="fsStatus"></div>
    </div>
  </div>

</div><!-- /sb -->

<div class="prev">
  <div class="pinner">
    <canvas id="postCanvas" width="1080" height="1080"></canvas>
    <div class="cap-card" id="capCard" style="width:400px;">
      <div class="cap-text" id="capText">Caption appears here after generating.</div>
      <div class="cap-tags" id="capTags"></div>
    </div>
  </div>
  <div class="toast" id="toast"></div>
</div>
</div>

<script>
const BRANDS={
