<script>
// run before other scripts so overlay shows immediately
(function(){
  // check if already authenticated this session
  if(sessionStorage.getItem('klaude_auth')==='1'){
    document.getElementById('pwOverlay').style.display='none';
  }
})();

function checkPW(){
  const val=document.getElementById('pwInput').value;
  if(val==='SuperKlaude'){
    sessionStorage.setItem('klaude_auth','1');
    const overlay=document.getElementById('pwOverlay');
    overlay.style.transition='opacity .4s';
    overlay.style.opacity='0';
    setTimeout(()=>overlay.style.display='none',400);
  } else {
    const err=document.getElementById('pwErr');
    const input=document.getElementById('pwInput');
    err.style.opacity='1';
    input.style.borderColor='rgba(239,68,68,.6)';
    input.value='';
    input.focus();
    setTimeout(()=>input.style.borderColor='rgba(255,255,255,.07)',1500);
  }
}
</script>

