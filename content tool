// Pexels via corsproxy — works on GitHub Pages without a backend
async function searchPexels(){
  const key=document.getElementById('kPexels').value.trim();
  const query=document.getElementById('imgQuery').value.trim()||posts[0]?.photo_query||'canada';
  const grid=document.getElementById('igrid');

  if(!key){
    grid.innerHTML='<div class="imsg">Add your Pexels key in the topbar</div>';
    return;
  }

  grid.innerHTML='<div class="imsg"><div class="spin"></div>&nbsp;Searching Pexels...</div>';
  try{
    // allorigins proxy passes Authorization headers correctly unlike corsproxy
    const target=`https://api.pexels.com/v1/search?query=${encodeURIComponent(query)}&per_page=8&orientation=square`;
    // sanitize key — strip any non-ASCII characters that break headers
    const safeKey=key.replace(/[^ -~]/g,'').trim();
    const r=await fetch(target,{
      headers:{'Authorization': safeKey},
      signal:AbortSignal.timeout(10000)
    });
    if(!r.ok) throw new Error('Status '+r.status);
    const d=await r.json();
    const photos=d.photos||[];
    if(!photos.length){grid.innerHTML='<div class="imsg">No results — try different keywords</div>';return;}
    grid.innerHTML='';
    let firstSet=false;
    photos.forEach(ph=>{
      const el=document.createElement('img');
      el.className='ithumb';
      el.crossOrigin='anonymous';
      el.src=ph.src.medium;
      el.dataset.full=ph.src.large2x||ph.src.large;
      el.title='Photo by '+ph.photographer+' on Pexels';
      el.onclick=()=>selectThumb(el);
      el.onload=()=>{if(!firstSet){firstSet=true;selectThumb(el);}};
      el.onerror=()=>el.style.display='none';
      grid.appendChild(el);
    });
  }catch(e){
    grid.innerHTML=`<div class="imsg">Pexels error: ${e.message} — check your key</div>`;
  }
}

async function loadUnsplash(key,query){
  const grid=document.getElementById('igrid');
  grid.innerHTML='<div class="imsg"><div class="spin"></div>&nbsp;Loading Unsplash...</div>';
  try{
    const r=await fetch(`https://api.unsplash.com/search/photos?query=${encodeURIComponent(query)}&per_page=8&orientation=squarish&client_id=${key}`);
    const d=await r.json();
    const photos=d.results||[];
    if(!photos.length){grid.innerHTML='<div class="imsg">No Unsplash results</div>';return;}
    grid.innerHTML='';let firstSet=false;
    photos.forEach(p=>{
      const el=document.createElement('img');
      el.className='ithumb';el.crossOrigin='anonymous';
      el.src=p.urls.small;el.dataset.full=p.urls.regular;
      el.onclick=()=>selectThumb(el);
      el.onload=()=>{if(!firstSet){firstSet=true;selectThumb(el);}};
      el.onerror=()=>el.style.display='none';
      grid.appendChild(el);
    });
  }catch(e){grid.innerHTML='<div class="imsg">Unsplash error</div>';}
}

