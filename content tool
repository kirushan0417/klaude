  const lc=B().localCat;
  const mix=MIXES[postCount].map(m=>m.replace('LOCAL_CAT',lc)).join(', ');
  // Build numbered headline list so Claude can reference them by index
  const numberedHeadlines=headlines.slice(0,10);
  const newsCtx=numberedHeadlines.length
    ?'\nToday\'s real headlines (use source_index to reference which one inspired each post):\n'
      +numberedHeadlines.map((h,i)=>`${i}: ${h}`).join('\n')
    :'';

  const prompt=`Today is ${today}.${newsCtx}

Generate exactly ${postCount} post${postCount>1?'s':''} using this mix: ${mix}.

- category: exact string from the mix
- headline: ALL CAPS max 10 words, tabloid energy, NO period
- caption: 1-2 sentences, casual, emoji at end, starts with "${B().handle}"
- hashtags: 5 tags as array
- photo_query: 3-word Unsplash fallback query
- source_index: the index number (0-9) of the headline above that inspired this post, or -1 if none

Respond ONLY with valid JSON array, no markdown:
[{"category":"...","headline":"...","caption":"...","hashtags":["..."],"photo_query":"...","source_index":0}]`;

  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'x-api-key':ck,'anthropic-version':'2023-06-01','content-type':'application/json','anthropic-dangerous-direct-browser-access':'true'},
      body:JSON.stringify({model:'claude-sonnet-4-6',max_tokens:1400,system:B().system,messages:[{role:'user',content:prompt}]})
    });
    const d=await r.json();
    if(d.error)throw new Error(d.error.message);
    let txt=d.content[0].text.trim().replace(/```json|```/g,'').trim();
    const si=txt.indexOf('['),ei=txt.lastIndexOf(']');
    if(si>-1&&ei>-1)txt=txt.slice(si,ei+1);
    posts=JSON.parse(txt);
    renderCards();
    await selectPost(0);
  }catch(e){alert('Claude error: '+e.message);}
  document.getElementById('fbtn').disabled=false;
  setLoader(false);
}

function renderCards(){
  const list=document.getElementById('slist');list.innerHTML='';
  posts.forEach((p,i)=>{
    const col=cCol(p.category);
    const srcItem=rssItems[i]||rssItems[0]||null;
    const srcLink=srcItem?.link||null;
    const srcTitle=srcItem?.title||null;
    const el=document.createElement('div');
    el.className='scard';el.id='sc'+i;
    el.innerHTML=`
      <div class="scard-top">
        <span class="spill" style="background:${col};">${p.category}</span>
        <span class="snum">#${i+1}</span>
      </div>
      <div class="stitle">${p.headline.toUpperCase()}</div>
      ${srcLink ? `<a class="src-link" href="${srcLink}" target="_blank" rel="noopener" onclick="event.stopPropagation()">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        View original story
      </a>` : ''}
    `;
    el.onclick=()=>selectPost(i);
    list.appendChild(el);
  });
}

async function selectPost(i){
  const p=posts[i];if(!p)return;
  selCat=p.category;
  document.querySelectorAll('.scard').forEach(c=>c.classList.remove('on','ace-card'));
  const sc=document.getElementById('sc'+i);
  if(sc){sc.classList.add('on');if(brand==='ace')sc.classList.add('ace-card');}
  document.getElementById('fHead').value=p.headline.toUpperCase();
  document.getElementById('fCap').value=p.caption;
  updateCap();
  document.getElementById('capTags').textContent=(p.hashtags||[]).join(' ');
  renderCanvas();

  // source panel — always show outlet + date + headline from rssItems
  const panel = document.getElementById('srcPanel');
  const outlet = brand === 'jc' ? 'CBC News' : 'ABC News';
  const ac = B().accent;

  // just use the post index directly — post 0 = rssItem 0 etc
  const srcItem = rssItems[i] || rssItems[0] || null;

  if (srcItem) {
    let dateStr = 'Today';
    if (srcItem.pubDate && !isNaN(new Date(srcItem.pubDate).getTime())) {
      dateStr = new Date(srcItem.pubDate).toLocaleDateString('en-CA', {
        year: 'numeric', month: 'short', day: 'numeric'
      });
    }
    const linkBtn = srcItem.link
      ? `<a href="${srcItem.link}" target="_blank" rel="noopener"
           style="margin-top:9px;display:inline-flex;align-items:center;gap:5px;
                  font-size:10px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;
                  color:${ac};text-decoration:none;border:1px solid ${ac}55;
                  border-radius:5px;padding:6px 12px;background:${ac}12;transition:background .15s;"
           onmouseover="this.style.background='${ac}28'" onmouseout="this.style.background='${ac}12'">
           <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
             <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
             <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
           </svg>
           Read on ${outlet} →
         </a>`
      : `<div style="font-size:9px;color:var(--muted);margin-top:6px;font-style:italic;">
           Direct link not in RSS feed
         </div>`;

    panel.innerHTML = `
      <div style="display:flex;align-items:center;gap:7px;margin-bottom:7px;">
        <span style="font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;
                     color:${ac};background:${ac}18;border:1px solid ${ac}44;
                     border-radius:4px;padding:2px 8px;">${outlet}</span>
        <span style="font-size:10px;color:var(--muted2);">${dateStr}</span>
      </div>
      <div style="font-size:11px;color:var(--text);line-height:1.5;font-weight:500;">
        ${srcItem.title || ''}
      </div>
      ${linkBtn}`;
  } else {
    panel.innerHTML = `<div style="font-size:10px;color:var(--muted);font-style:italic;">
      Hit Generate to see source info
    </div>`;
  }

  // auto-search Pexels if key is set, else retry for article images
  const pxKey=document.getElementById('kPexels').value.trim();
  if(pxKey){
    document.getElementById('imgQuery').value=p.photo_query||'';
    await searchPexels();
  } else {
    await loadPhotoGrid();
  }
}

function download(){
  if(!document.getElementById('fHead').value){alert('Generate a post first.');return;}
  renderCanvas();
  setTimeout(()=>{
    try{
      const a=document.createElement('a');
      a.download=`${brand}_post_${Date.now()}.jpg`;
      a.href=canvas.toDataURL('image/jpeg',0.95);
      a.click();toast('Downloaded ✓');
    }catch(e){alert('Right-click the post image and Save As.\nError: '+e.message);}
  },150);
}

// init
fsLoad();
// restore pexels key to topbar from storage
const _cfg=fsGet();
if(_cfg.pexelsKey){
  document.getElementById('kPexels').value=_cfg.pexelsKey;
  document.getElementById('pxdot').classList.add('ok');
}
document.fonts.ready.then(()=>{fontsReady=true;renderCanvas();});
renderCanvas();
</script>
