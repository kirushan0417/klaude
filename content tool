// canvas
const canvas=document.getElementById('postCanvas');
const ctx=canvas.getContext('2d');
const SZ=1080;

function sizeCanvas(){
  const area=document.querySelector('.prev');
  const avail=Math.min(area.clientWidth-48,area.clientHeight-130,430);
