function renderCanvas(){
  ctx.clearRect(0,0,SZ,SZ);

  // bg
  if(currentImg){
    ctx.filter=`brightness(${brightness/100}) saturate(1.06)`;
    const iw=currentImg.naturalWidth||currentImg.width||SZ;
    const ih=currentImg.naturalHeight||currentImg.height||SZ;
    const sc=Math.max(SZ/iw,SZ/ih);
    ctx.drawImage(currentImg,(SZ-iw*sc)/2,(SZ-ih*sc)/2,iw*sc,ih*sc);
    ctx.filter='none';
  } else {
    ctx.fillStyle='#0e0e12';ctx.fillRect(0,0,SZ,SZ);
    ctx.strokeStyle='rgba(255,255,255,0.025)';ctx.lineWidth=1;
    for(let i=0;i<SZ;i+=60){ctx.beginPath();ctx.moveTo(i,0);ctx.lineTo(i,SZ);ctx.stroke();ctx.beginPath();ctx.moveTo(0,i);ctx.lineTo(SZ,i);ctx.stroke();}
  }

  // gradient — strong at bottom
  const g=ctx.createLinearGradient(0,0,0,SZ);
  g.addColorStop(0.0,'rgba(0,0,0,0.02)');
  g.addColorStop(0.20,'rgba(0,0,0,0.0)');
  g.addColorStop(0.48,'rgba(0,0,0,0.5)');
  g.addColorStop(0.68,'rgba(0,0,0,0.84)');
  g.addColorStop(0.82,'rgba(0,0,0,0.96)');
  g.addColorStop(1.0,'rgba(0,0,0,1.0)');
  ctx.fillStyle=g;ctx.fillRect(0,0,SZ,SZ);

  // handle — light or dark
  ctx.font=`600 28px ${fontsReady?'DM Sans':'sans-serif'}`;
  if(handleStyle==='dark'){
    ctx.fillStyle='rgba(0,0,0,0.82)';
    ctx.shadowColor='rgba(255,255,255,0.3)';
  } else {
    ctx.fillStyle='rgba(255,255,255,0.82)';
    ctx.shadowColor='rgba(0,0,0,0.9)';
  }
  ctx.shadowBlur=10;
  ctx.fillText(B().handle,44,64);
  ctx.shadowBlur=0;

  // ── BOTTOM SECTION — pixel-perfect, built top-down after measuring total height
  const PAD     = 44;
  const HL_SIZE = 76;
  const HL_LH   = HL_SIZE * 1.12;   // real line height ≈ font-size × 1.12
  const PILL_H  = 42;
  const PILL_PAD= 22;
  const DOT_R   = 10;
  const GAP_DOT_PILL = 18;  // gap between bottom of dot and top of pill
  const GAP_PILL_HL  = 14;  // gap between bottom of pill and top of first line
  const BOT_PAD = 50;       // breathing room from very bottom edge

  const col       = cCol(selCat);
  const pillLabel = selCat==='LOCAL' ? B().localCat : selCat;
  const hl        = (document.getElementById('fHead').value || 'YOUR HEADLINE APPEARS HERE').toUpperCase();

  // 1. measure headline lines using actual font
  const HL_FONT  = `bold ${HL_SIZE}px ${fontsReady?'Bebas Neue':'Impact,sans-serif'}`;
  const PILL_FONT= `700 22px ${fontsReady?'DM Sans':'sans-serif'}`;
  ctx.font = HL_FONT;
  const hlLines  = wrapText(ctx, hl, HL_FONT, SZ - PAD * 2);

  // 2. total block height (dot + gap + headline + bottom padding)
  const hlBlockH  = hlLines.length * HL_LH;
  const totalH    = DOT_R * 2
                  + GAP_DOT_PILL
                  + hlBlockH
                  + BOT_PAD;

  // 3. anchor so bottom of block sits at SZ
  const blockTop  = SZ - totalH;

  // 4. positions
  const dotCY     = blockTop + DOT_R;
  const hlFirst   = dotCY + DOT_R + GAP_DOT_PILL + HL_SIZE;

  // 5. stripe OR dot above headline
  if(showStripe){
    // two horizontal white lines with brand dot in centre gap
    const STRIPE_Y   = hlFirst - HL_SIZE - 30;
    const STRIPE_W   = SZ - PAD * 2;
    const LINE_H     = 3;
    const LINE_GAP   = 8;
    ctx.shadowBlur   = 0;

    // top line
    ctx.fillStyle = 'rgba(255,255,255,0.9)';
    ctx.fillRect(PAD, STRIPE_Y, STRIPE_W, LINE_H);
    // bottom line
    ctx.fillRect(PAD, STRIPE_Y + LINE_H + LINE_GAP, STRIPE_W, LINE_H);

    // brand dot centred between the two lines
    const dotMidY = STRIPE_Y + LINE_H + LINE_GAP / 2;
    ctx.beginPath();
    ctx.arc(SZ/2, dotMidY, DOT_R + 1, 0, Math.PI*2);
    ctx.fillStyle = '#000'; ctx.fill(); // knockout circle to cut through lines
    ctx.beginPath();
    ctx.arc(SZ/2, dotMidY, DOT_R, 0, Math.PI*2);
    ctx.fillStyle = col; ctx.fill();
    ctx.strokeStyle = '#000'; ctx.lineWidth = 2.5; ctx.stroke();
  } else {
    // plain dot only
    ctx.beginPath();
    ctx.arc(SZ/2, dotCY, DOT_R, 0, Math.PI*2);
    ctx.fillStyle = col; ctx.fill();
    ctx.strokeStyle = '#000'; ctx.lineWidth = 3; ctx.stroke();
  }

  // 6. draw headline lines downward
  ctx.font = HL_FONT;
  ctx.fillStyle = '#ffffff';
  ctx.shadowColor = 'rgba(0,0,0,0.98)'; ctx.shadowBlur = 22;
  let ty = hlFirst;
  hlLines.forEach(line => {
    ctx.fillText(line, PAD, ty);
    ty += HL_LH;
  });
  ctx.shadowBlur = 0;
}

function rrect(ctx,x,y,w,h,r,fill){
  ctx.beginPath();
  ctx.moveTo(x+r,y);ctx.lineTo(x+w-r,y);ctx.quadraticCurveTo(x+w,y,x+w,y+r);
  ctx.lineTo(x+w,y+h-r);ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
  ctx.lineTo(x+r,y+h);ctx.quadraticCurveTo(x,y+h,x,y+h-r);
  ctx.lineTo(x,y+r);ctx.quadraticCurveTo(x,y,x+r,y);
  ctx.closePath();ctx.fillStyle=fill;ctx.fill();
}

function wrapText(ctx,text,fontStr,maxW){
  ctx.font=fontStr;
  const words=text.split(' ');const lines=[];let cur='';
  words.forEach(w=>{
    const t=cur?cur+' '+w:w;
    if(ctx.measureText(t).width>maxW&&cur){lines.push(cur);cur=w;}else cur=t;
  });if(cur)lines.push(cur);return lines;
}

