// RSS scraper
// Extract CBC article og:image by fetching the article page
async function fetchArticleImage(articleUrl){
  if(!articleUrl) return null;
  try{
    const proxy='https://corsproxy.io/?'+encodeURIComponent(articleUrl);
    const r=await fetch(proxy,{signal:AbortSignal.timeout(6000)});
    if(!r.ok) return null;
    const html=await r.text();
    // og:image is the most reliable
    const m=html.match(/<meta[^>]+property=["']og:image["'][^>]+content=["']([^"']+)["']/i)
           ||html.match(/<meta[^>]+content=["']([^"']+)["'][^>]+property=["']og:image["']/i);
    if(m&&m[1]) return m[1];
    // fallback: first large jpg in page
    const m2=html.match(/https?:\/\/[^"'<>\s]+\.(?:jpg|jpeg|png|webp)[^"'<>\s]*/i);
    return m2?m2[0]:null;
  }catch(e){ return null; }
}

async function scrapeRSS(urls){
  const items=[];
  for(const url of urls.slice(0,2)){
    try{
      const proxy='https://corsproxy.io/?'+encodeURIComponent(url);
      const r=await fetch(proxy,{signal:AbortSignal.timeout(8000)});
      if(!r.ok) continue;
      const raw=await r.text();
      const doc=new DOMParser().parseFromString(raw,'text/xml');

      for(const item of [...doc.querySelectorAll('item')].slice(0,10)){
        const title=item.querySelector('title')?.textContent?.trim();

        // CBC link lives in a text node AFTER the <link> tag, not inside it
        // Best approach: grab raw XML of item and regex the link
        const itemXml=new XMLSerializer().serializeToString(item);

        // Extract link — try multiple patterns
        let link=null;
        const lm1=itemXml.match(/<link[^>]*>([^<]+)<\/link>/i);
        const lm2=itemXml.match(/<link[^>]*\/?>\s*([^<\s][^\s]*cbc\.ca[^\s<"']*)/i);
        const lm3=itemXml.match(/https?:\/\/(?:www\.)?cbc\.ca\/[^"'<>\s]+/i)
                 ||itemXml.match(/https?:\/\/(?:www\.)?abcnews\.go\.com\/[^"'<>\s]+/i)
                 ||itemXml.match(/https?:\/\/(?:www\.)?nytimes\.com\/[^"'<>\s]+/i);
        if(lm1&&lm1[1]?.includes('http')) link=lm1[1].trim();
        else if(lm2) link=lm2[1].trim();
        else if(lm3) link=lm3[0].trim();

        // Also try standard querySelector as fallback
        if(!link){
          link=item.getElementsByTagName('link')[0]?.nextSibling?.nodeValue?.trim()||null;
        }

        // Image: try all RSS image fields first
        let img=null;
        const allEls=[...item.getElementsByTagName('*')];
        for(const el of allEls){
          const tag=el.tagName.toLowerCase();
          if(tag.includes('thumbnail')||tag.includes('content')){
            const u=el.getAttribute('url');
            if(u&&u.match(/\.(jpg|jpeg|png|webp)/i)){img=u;break;}
          }
        }
        if(!img){
          const enc=item.querySelector('enclosure');
          const u=enc?.getAttribute('url');
          if(u&&u.match(/\.(jpg|jpeg|png|webp)/i)) img=u;
        }
        if(!img){
          const desc=item.querySelector('description')?.textContent||'';
          const m=desc.match(/src=["'](https?:\/\/[^"'\s]+\.(?:jpg|jpeg|png|webp)[^"'\s]*)/i);
          if(m) img=m[1];
        }
        if(!img){
          const m=itemXml.match(/https?:\/\/[^"'<>\s]+\.(?:jpg|jpeg|png|webp)/i);
          if(m) img=m[0];
        }

        // Date filter — last 12 months only
        let pubDate=null;
        const pdEl=item.querySelector('pubDate')||item.querySelector('published')||item.querySelector('updated');
        if(pdEl) pubDate=new Date(pdEl.textContent.trim());
        const cutoff=new Date(); cutoff.setFullYear(cutoff.getFullYear()-1);
        const dateOk=!pubDate||isNaN(pubDate.getTime())||(pubDate>=cutoff);

        if(title&&!title.includes('[Removed]')&&dateOk){
          items.push({title,img,link,pubDate});
        }
      }
    }catch(e){ console.warn('RSS:',url,e.message); }
  }

  // Sort newest first
  items.sort((a,b)=>(!a.pubDate?1:!b.pubDate?-1:b.pubDate-a.pubDate));

  // Fetch article images for items that have a link but no image (async, fill in background)
  items.forEach(async item=>{
    if(!item.img&&item.link){
      item.img=await fetchArticleImage(item.link);
    }
  });

  return items;
}

// NewsAPI fallback
async function scrapeNewsAPI(key,country){
  try{
    const r=await fetch('https://corsproxy.io/?'+encodeURIComponent(`https://newsapi.org/v2/top-headlines?country=${country}&pageSize=10&apiKey=${key}`),{signal:AbortSignal.timeout(8000)});
    if(!r.ok)return[];
    const d=await r.json();
    return(d.articles||[]).filter(a=>a.title&&!a.title.includes('[Removed]')).map(a=>({title:a.title,img:a.urlToImage||null,link:a.url||null}));
  }catch(e){return[];}
}

