    rss:['https://feeds.abcnews.com/abcnews/topstories','https://feeds.abcnews.com/abcnews/usheadlines','https://rss.nytimes.com/services/xml/rss/nyt/HomePage.xml'],
    system:'You create viral Instagram posts for "ACE.com" styled like Nugget, Puberty, WorldStar. Mix: surprising USA facts, wild true stories, feel-good moments, funny Only-in-America content, max 1 casino tip per batch. Headlines: tabloid front page energy, impossible to scroll past, NOT corporate.'
  }
};
const MIXES={
